# ───────────────────────────────────────────────────────────────────
# DeshVox — Environment Variables
# Copy this file to .env or .env.local and fill in your values
# ───────────────────────────────────────────────────────────────────

# ── Prisma + Supabase Postgres ─────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@db.xxxxxxxxxxxxxx.supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
# ^ Direct connection from Vercel to Supabase (with PgBouncer for serverless)
DIRECT_URL="postgresql://postgres:password@db.xxxxxxxxxxxxxx.supabase.co:5432/postgres"
# ^ Non-pooled connection used for Prisma Migrate (not PgBouncer compatible)

# ── Supabase Auth ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# ── Retell AI (Voice Agent) ───────────────────────────────────────
RETELL_API_KEY=retell_api_key_xxxx
RETELL_AGENT_ID=agent_xxxxxxxxxxxx

# ── Multi-tenant Demo (optional) ───────────────────────────────────
DEMO_TENANT_ID=00000000-0000-0000-0000-000000000001

# ── In-Memory Rate Limiting (single-instance only) ────────────────
# These are safe for a single Vercel instance. For production on
# multiple instances, replace with Upstash Redis (see checklist).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
